# Required in production when using sign-in
# Generate: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth (optional — guest mode works without these)
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Public URL of your deployment (required for OAuth callbacks in production)
# Local: http://localhost:3000
# Production: https://your-domain.com
AUTH_URL=http://localhost:3000
